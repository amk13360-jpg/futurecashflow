# Database Configuration (REQUIRED)
DB_HOST=your-database-host
DB_NAME=your-database-name
DB_USER=your-database-user
DB_PASSWORD=your-secure-database-password
DB_PORT=3306

# JWT Configuration (REQUIRED - Generate with: openssl rand -base64 64)
JWT_SECRET=generate-a-secure-random-secret-min-256-bits

# Node Environment
NODE_ENV=development

# Application URL
NEXTAUTH_URL=http://localhost:3000

# Azure Communication Services (Optional for email)
AZURE_COMMUNICATION_CONNECTION_STRING=your-azure-communication-connection-string
AZURE_COMMUNICATION_SENDER=your-sender-email@azurecomm.net

# Azure Blob Storage (Optional for file uploads)
AZURE_STORAGE_CONNECTION_STRING=your-azure-storage-connection-string
AZURE_STORAGE_CONTAINER_NAME=cession-agreements

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security
ALLOWED_ORIGINS=http://localhost:3000
