    },
    "AZURE_RESOURCE_GROUP": {
      "type": "string",
      "value": "[resourceGroup().name]"
    },
    "SERVICE_WEB_NAME": {
      "type": "string",
      "value": "[format('{0}{1}-{2}', variables('abbrs').webSitesAppService, parameters('resourceNamePrefix'), variables('resourceToken'))]"
    },
    "SERVICE_WEB_URI": {
      "type": "string",
      "value": "[format('https://{0}.azurewebsites.net', format('{0}{1}-{2}', variables('abbrs').webSitesAppService, parameters('resourceNamePrefix'), variables('resourceToken')))]"
    },
    "MYSQL_HOST": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.DBforMySQL/flexibleServers', format('{0}{1}-{2}', variables('abbrs').dBforMySQLServers, parameters('resourceNamePrefix'), variables('resourceToken'))), '2023-06-30').fullyQualifiedDomainName]"
    },
    "MYSQL_DATABASE_NAME": {
      "type": "string",
      "value": "[parameters('databaseName')]"
    }
  }
